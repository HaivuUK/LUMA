{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "luma",
  "version": "0.3.1",
  "identifier": "org.haivu.luma",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "rpm", "dmg", "app", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["LICENSE.txt"],
    "category": "Medical",
    "license": "AGPL-3.0-or-later",
    "licenseFile": "LICENSE.txt",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "buildscripts/win/nsishooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["buildscripts/win/wixhooks.wxs"],
        "componentRefs": ["AppendPathEnv"]
      }
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/share/README.md": "README.md"
        }
      },
      "rpm": {
        "provides": ["luma"],
        "recommends": ["webkit2gtk4.1", "webkit2gtk4", "libwebkit2gtk-4_1-0", "webkit2gtk-4_1-injected-bundles"]
      },
      "appimage": {
        "files": {
          "/usr/share/README.md": "README.md"
        }
      }
    },
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
